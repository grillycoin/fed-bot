# 1. FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# 2. Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ

# 3. Your Telegram chat ID — send a message to your bot, then visit:
#    https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
#    Look for "chat": {"id": <number>}
TELEGRAM_CHAT_ID=your_chat_id_here

# 4. Upstash Redis — free at https://upstash.com (required for Render, optional locally)
#    Create a database → REST API tab → copy URL and token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
